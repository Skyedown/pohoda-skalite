{
  "name": "pizza-pohoda-api",
  "version": "1.0.0",
  "type": "module",
  "description": "API server for Pizza Pohoda",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch server.ts",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.ts\"",
    "format:check": "prettier --check \"**/*.ts\"",
    "ci": "npm run format:check && npm run lint && npm run typecheck"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.0",
    "amqplib": "^0.10.5",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "mongoose": "^8.9.0",
    "sanitize-html": "^2.11.0",
    "validator": "^13.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/amqplib": "^0.10.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.0",
    "@types/sanitize-html": "^2.16.0",
    "@types/validator": "^13.15.10",
    "eslint": "^10.2.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2"
  }
}
